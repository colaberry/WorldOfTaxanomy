# WorldOfTaxanomy - environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret - must be at least 32 characters
# Generate one with: python3 -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=your-secret-at-least-32-chars-long

# Email address for session completion reports (sent via Gmail MCP)
REPORT_EMAIL=your@email.com

# Comma-separated list of allowed CORS origins for the API.
# Leave unset in local dev to allow http://localhost:3000 and http://127.0.0.1:3000.
# In production, set to your frontend origin(s), e.g.:
#   ALLOWED_ORIGINS=https://worldoftaxonomy.com,https://www.worldoftaxonomy.com
ALLOWED_ORIGINS=
